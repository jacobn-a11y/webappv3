{
  "name": "storyengine",
  "version": "1.0.0",
  "engines": {
    "node": ">=22.0.0"
  },
  "description": "B2B SaaS - Consolidate call recordings into Account Journey views with AI-powered story extraction",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:migrate:reset": "prisma migrate reset",
    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts",
    "db:setup": "prisma migrate deploy && tsx prisma/seed.ts",
    "db:normalize:enums:dry": "node scripts/migrations/run-enum-normalizations.mjs",
    "db:normalize:enums": "node scripts/migrations/run-enum-normalizations.mjs --apply",
    "db:migrate:smoke": "node scripts/migrations/migration-smoke.mjs",
    "db:seed:volume": "node scripts/load/seed-staging-volume.mjs",
    "db:seed:volume:dry-run": "node scripts/load/seed-staging-volume.mjs --dry-run",
    "db:test:push": "DATABASE_URL=$TEST_DATABASE_URL prisma db push --skip-generate",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:reset": "docker compose down -v && docker compose up -d",
    "lint": "eslint src/",
    "test": "vitest run",
    "test:security": "vitest run tests/tenant-isolation-routes.test.ts tests/policy-engine.test.ts tests/support-impersonation-middleware.test.ts tests/pii-masking-hardening.test.ts tests/csrf-protection-middleware.test.ts tests/webhook-security.test.ts tests/integration/admin-controls-readiness.integration.test.ts tests/integration/incident-status-routes.integration.test.ts",
    "test:reliability": "vitest run tests/integration/sync-engine-chaos.test.ts tests/call-processing-dead-letter-replay.test.ts tests/queue-policy.test.ts tests/ai-resilience.test.ts tests/transcript-processor-large-input.test.ts tests/webhook-idempotency.test.ts tests/performance-regression.test.ts tests/perf-endpoint-load-budget.test.ts tests/integration/customer-success-routes.integration.test.ts && npm --prefix frontend run -s test:a11y",
    "test:e2e:enterprise": "vitest run tests/integration/support-impersonation-routes.integration.test.ts tests/e2e/launch-checklist-cli.test.ts tests/e2e/release-gate-cli.test.ts tests/e2e/volume-seed-cli.test.ts tests/e2e/admin-controls-validation-cli.test.ts tests/e2e/self-service-journey.e2e.test.ts",
    "test:release": "vitest run -c vitest.release.config.ts",
    "test:release:coverage": "vitest run -c vitest.release.config.ts --coverage",
    "test:release:stability": "sh -c 'for i in 1 2 3; do echo \"release suite run $i\"; npm run -s test:release || exit 1; done'",
    "test:contracts": "vitest run tests/contracts/ingest-payload-parity.contract.test.ts",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "security:deps": "node scripts/security/dependency-audit-check.mjs",
    "perf:budget": "node scripts/perf/check-budgets.mjs",
    "perf:load": "node scripts/perf/load-profile.mjs",
    "launch:checklist": "node scripts/launch/run-launch-checklist.mjs",
    "launch:gate": "node scripts/launch/run-release-gates.mjs",
    "launch:gate:p1": "node scripts/launch/run-release-gates.mjs --p1",
    "launch:evidence": "node scripts/launch/generate-release-evidence.mjs",
    "launch:validate-admin-controls": "node scripts/launch/validate-admin-controls.mjs",
    "contracts:check": "node scripts/contracts/check-contract-freeze.mjs",
    "contracts:update": "node scripts/contracts/check-contract-freeze.mjs --update",
    "contracts:file-size:warn": "node scripts/contracts/file-size-guard.mjs",
    "contracts:file-size:check": "node scripts/contracts/file-size-guard.mjs --strict",
    "migrate:safety": "node scripts/migration-safety-check.mjs",
    "smoke:test": "node scripts/smoke/smoke-test.mjs",
    "migrate:safety:baseline": "node scripts/migration-safety-check.mjs --update-baseline",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\"",
    "prepare": "husky"
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/exporter-metrics-otlp-http": "^0.212.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.212.0",
    "@opentelemetry/instrumentation-express": "^0.59.0",
    "@opentelemetry/instrumentation-http": "^0.212.0",
    "@opentelemetry/resources": "^2.5.1",
    "@opentelemetry/sdk-metrics": "^2.5.1",
    "@opentelemetry/sdk-node": "^0.212.0",
    "@opentelemetry/semantic-conventions": "^1.39.0",
    "@pinecone-database/pinecone": "^3.0.0",
    "@prisma/client": "^5.20.0",
    "@prisma/instrumentation": "^7.4.0",
    "@sentry/node": "^10.38.0",
    "@workos-inc/node": "^7.0.0",
    "bullmq": "^5.20.0",
    "cors": "^2.8.5",
    "diff": "^8.0.3",
    "docx": "^9.6.0",
    "express": "^4.21.0",
    "fuse.js": "^7.0.0",
    "googleapis": "^171.4.0",
    "helmet": "^8.0.0",
    "node-cron": "^3.0.3",
    "openai": "^4.70.0",
    "pdf-lib": "^1.17.1",
    "puppeteer-core": "^24.37.3",
    "redis": "^5.11.0",
    "resend": "^6.9.2",
    "stripe": "^17.0.0",
    "uuid": "^13.0.0",
    "winston": "^3.14.0",
    "zod": "^3.23.0"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/cors": "^2.8.17",
    "@types/diff": "^7.0.2",
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "@types/node-cron": "^3.0.11",
    "@types/supertest": "^6.0.3",
    "@types/uuid": "^10.0.0",
    "eslint": "^9.0.0",
    "globals": "^16.4.0",
    "prisma": "^5.22.0",
    "supertest": "^7.2.2",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.55.0",
    "vitest": "^4.0.18",
    "husky": "^9.0.0",
    "lint-staged": "^15.0.0"
  },
  "lint-staged": {
    "*.{ts,tsx,mts}": ["eslint --fix"],
    "*.{ts,tsx,mts,css,json,md}": ["prettier --write"]
  }
}
